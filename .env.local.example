# Required for real searches (optional in DEMO_MODE)
FACECHECK_API_KEY=
SERPAPI_KEY=
YANDEX_SEARCH_API_KEY=
OPENAI_API_KEY=

# Local services (docker-compose up)
COMPREFACE_URL=http://localhost:8000
COMPREFACE_API_KEY=
NUDENET_URL=http://localhost:5001
NUDENET_ENABLED=true

# App
DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Budget tier (~$0): only COMPREFACE + NUDENET required ---
# Optional: SERPAPI_KEY for 1 Google Lens search per budget scan (~$0.01)

# --- Full tier (~$65-115/mo): add FACECHECK + SERPAPI + OPENAI ---